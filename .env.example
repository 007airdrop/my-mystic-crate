# Wallet private key that deploys the NFT contract (needs Base ETH for gas).
# Use the same wallet as your treasury, or a separate deployer.
DEPLOYER_PRIVATE_KEY=

# Optional custom Base RPC
BASE_RPC_URL=https://mainnet.base.org

# Set automatically by npm run deploy:base, or paste after deploy:
NEXT_PUBLIC_NFT_CONTRACT_ADDRESS=
