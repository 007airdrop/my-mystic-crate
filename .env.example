# Deployer wallet private key — LOCAL ONLY. Never commit, paste in chat, or add to Vercel.
# Use only when running: npm run deploy:base (then remove from .env.local)
DEPLOYER_PRIVATE_KEY=

# Optional custom Base RPC
BASE_RPC_URL=https://mainnet.base.org

# Set automatically by npm run deploy:base, or paste after deploy:
NEXT_PUBLIC_NFT_CONTRACT_ADDRESS=
